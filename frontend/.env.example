# CampaignSim frontend environment (copy to `.env` or `.env.local`)

# Base URL for the Flask/backend API when VITE_USE_MOCKS=false
VITE_API_BASE_URL=http://localhost:5001

# Mock mode: any value except the string "false" enables in-browser mock API.
# Set to false only when the real backend implements the contract routes.
VITE_USE_MOCKS=true
